 <!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN, cannot be changed between the plugin versions. -->
    <id>cw.chaos.cw2_frp</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
    <name>FRP.Gen1</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor email="nekomorph.woo@gmail.com" url="https://github.com/nekomorph-woo" icon="/META-INF/pluginIcon.svg">Chaos Woo</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
    <description><![CDATA[
        Generate File Reference Pointer (FRP) for CLI AI tools like Claude Code.<br>
        Select text in editor, right-click to generate reference format like:<br>
        <code>#frp1 to src/main/java/Example.java #L20-30</code>
    ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <!-- Kotlin 插件设为可选 -->
    <depends optional="true">org.jetbrains.kotlin</depends>

    <resource-bundle>messages.MyMessageBundle</resource-bundle>

    <!-- Extensions defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="MyToolWindow" factoryClass="cw.chaos.cw2_frp.MyToolWindowFactory"
                    icon="AllIcons.Toolwindows.ToolWindowPalette"/>

        <!-- 通知组 -->
        <notificationGroup id="FRP Generator" displayType="BALLOON"/>
    </extensions>

    <!-- Actions -->
    <actions>
        <!-- 编辑器右键菜单 -->
        <group id="cw.chaos.cw2_frp.FRPActionGroup"
               class="cw.chaos.cw2_frp.FRPActionGroup"
               text="Gen #frp"
               description="生成文件引用指针并复制到剪贴板"
               popup="true"
               icon="AllIcons.Actions.Copy">
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
        </group>

        <!-- 项目树右键菜单 -->
        <group id="cw.chaos.cw2_frp.FRPProjectTreeActionGroup"
               class="cw.chaos.cw2_frp.FRPProjectTreeActionGroup"
               text="Gen #frp"
               description="生成文件/文件夹引用指针并复制到剪贴板"
               popup="true"
               icon="AllIcons.Actions.Copy">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="first"/>
        </group>
    </actions>
</idea-plugin>
